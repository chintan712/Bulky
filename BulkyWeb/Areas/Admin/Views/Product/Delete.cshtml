@model Product

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow rounded-4 border-0">
                <div class="card-body p-4">
                    <h4 class="mb-4 text-center fw-semibold">Delete Product</h4>

                    <form method="post" novalidate>
                        <input asp-for="Id" type="hidden" />
                        <div class="form-floating py-2 col-12">
                            <input asp-for="Title" disabled class="form-control" placeholder="Product Name" />
                            <label asp-for="Title">Title</label>
                        </div>
                        <div class="form-floating py-2 col-12">
                            <input asp-for="Description" disabled class="form-control" placeholder="Product Name" />
                            <label asp-for="Description">Description</label>
                        </div>

                        <div class="form-floating py-2 col-12">
                            <input asp-for="ISBN" disabled class="form-control" placeholder="Display Order" />
                            <label asp-for="ISBN">ISBN</label>
                        </div>
                        <div class="form-floating py-2 col-12">
                            <input asp-for="Author" disabled class="form-control" placeholder="Author" />
                            <label asp-for="Author">Author</label>
                        </div>
                        <div class="form-floating py-2 col-12">
                            <input asp-for="ListPrice" disabled class="form-control" placeholder="List Price" />
                            <label asp-for="ListPrice">List Price</label>
                        </div>
                        <div class="form-floating py-2 col-12">
                            <input asp-for="Price" disabled class="form-control" placeholder="List Price" />
                            <label asp-for="Price">Price</label>
                        </div>
                        <div class="form-floating py-2 col-12">
                            <input asp-for="Price50" disabled class="form-control" placeholder="List Price" />
                            <label asp-for="Price50">Price50</label>
                        </div>
                        <div class="form-floating py-2 col-12">
                            <input asp-for="Price100" disabled class="form-control" placeholder="List Price" />
                            <label asp-for="Price100">Price100</label>
                        </div>
                        <div class="d-flex justify-content-between">
                            <button type="submit" class="btn btn-danger  px-5">Delete</button>
                            <a asp-action="Index" class="btn btn-outline-secondary  px-5">Back to List</a>
                        </div>


                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
  
  