@model Category

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow rounded-4 border-0">
                <div class="card-body p-4">
                    <h4 class="mb-4 text-center fw-semibold">Edit Category</h4>

                    <form method="post" novalidate>
                        <input asp-for="Id" type="hidden" />
                        <div class="form-floating mb-3">
                            <input asp-for="Name" disabled class="form-control" placeholder="Category Name" />
                            <label asp-for="Name">Category Name</label>

                        </div>

                        <div class="form-floating mb-4">
                            <input asp-for="displayOrder" disabled class="form-control" placeholder="Display Order" />
                            <label asp-for="displayOrder">Display Order</label>


                        </div>
                        <div class="d-flex justify-content-between">
                            <button type="submit" class="btn btn-danger  px-5">Delete</button>
                            <a asp-action="Index" class="btn btn-outline-secondary  px-5">Back to List</a>
                        </div>


                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
  
  